VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# 아래 값들은 VITE_ 접두사가 없어야 함 — 서버(Netlify Functions)에서만 사용되며,
# 접두사가 붙으면 빌드 시 클라이언트 번들에 노출됨.
ANTHROPIC_API_KEY=
GOOGLE_CLOUD_API_KEY=

# ADMIN_PIN=여기에_평문PIN의_SHA256_해시값_입력
# 평문 PIN을 그대로 넣지 말 것. 해시값은 아래처럼 로컬에서 생성:
#   node -e "console.log(require('crypto').createHash('sha256').update('입력할PIN').digest('hex'))"
ADMIN_PIN=

# Firebase 콘솔 > 프로젝트 설정 > 서비스 계정 > 새 비공개 키 생성으로 받은
# JSON 파일 전체 내용을 한 줄 문자열로 등록 (netlify/functions/lib/firebaseAdmin.js에서 사용).
# users/documents 컬렉션의 실제 조회·수정·삭제는 모두 이 키로 서버에서만 수행되며,
# Firestore 보안 규칙(firestore.rules)은 클라이언트의 직접 접근을 차단한다.
FIREBASE_SERVICE_ACCOUNT_KEY=

# 로컬 개발에서만 true로 설정 (실제 Claude API를 호출하지 않고 Mock 데이터를 반환).
# Netlify 배포 환경에는 이 변수를 추가하지 말거나 false로 설정해야 함.
DEV_MOCK=true
